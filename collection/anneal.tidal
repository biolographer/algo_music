import Data.List

patternToList :: Pattern a -> [a]
patternToList pat = map value $ sortOn whole $ queryArc pat (Arc 0 1)


let mv = "-1 0 _ _ 1 2 2"
    tv = mv |- 1
    chords = "<a'm9 e'7sus4>"
    charp = n (arp "up" chords)
    x = patternToList charp


d1 $ n (arp "<up down>" chords) # sound "superpiano"

n (arp "up" chords) |- n "a5"


