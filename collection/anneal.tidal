let dorian = [0,2,3,5,7,9,10]

d1  $ fudgeToScale dorian
  $ juxBy 0.5 ((|+ up "[0,4,-5]") . (# s  "superpiano"))
  $ up "<[0 [2 3] 5 7] [4 <2 -2>]>" # s "superhammond"


let fudgeToScale scaleIntervals = fix (|- up 1) (up $ parseBP_E $ completeAvoidList scaleIntervals) where
                completeAvoidList scaleIntervals = show $ concat $ transposeScale avoidIntervals <$> [(-3)..3]
                transposeScale avoidIntervals oct = (+ (oct * 12)) <$> avoidIntervals
                avoidIntervals  = filter (\n -> notElem n scaleIntervals) [0..11]


(+ (1 * 12)) <$> [1,4,6,8,11]


let completeAvoidList = show $ concat $ transposeScale [4,4,7,7,11,11,13] <$> [(-3)..3]

parseBP_E $ completeAvoidList




do
  resetCycles
  d1 $ when (<=4) (striate 4) $ sound "hh hc"

do
  resetCycles
  let pat = "bd [~ sd]"
  let noCycles = 20
  d1 $ ifp (< noCycles)
    (# nudge (range 1 0 $ slow (noCycles*2) (cosine*rand )))
    (# gain 1) $
    s pat
  d2 $ s "sn" # speed 2



let anneal p = ifp (< 20) (# nudge ( range 0 2 $ slow (20*1.2) (cosine + 0.1*rand )))
  (# gain 1) $ p


getnow

d1 $ s "cp" # nudge 0.9

d2 $ s "sn" # pan 1

setcps 1.2

do
  resetCycles
  let cyclenr = 20
  let rrand = range 0.1 0.5 $ rand
  d1 $ ifp (< cyclenr)
    (# nudge (slow (2*cyclenr) $ smooth "1 0" * rrand))
    (# pan (range 0.2 0.6 $ sine))
    $ s "bd [~ sd] [hh, bd] sd"
  d2 $ s "drum" # speed 1.2

do
  let asdf =  sometimesBy 0.6 (# squiz (slow 2 $ "4 5 1 8?"))
              $ every 2 (jux (rev . ( 0.25 ~>))
              . (plyWith (slow 4 $  "2 2") ((|* gain 0.9) )
              . (|* speed "2 [5 1] 3? 6")))
              $ s "{bd [sd cr] bd  cr sn}%4"
              # n (irand 20)
              # gain 1
              # distort "0 0.2 0.8?"
  -- setcps 1
  -- resetCycles
  let cyclenr = 20
  let rrand = range 0.1 0.5 $ rand
  d1
    $ ifp (< cyclenr)
      ((# nudge ( slow (2*cyclenr) $ smooth "1 0" * 0.8 * rrand))
      . (# gain ( slow (2*cyclenr)$ smooth "0 1" )))
      (# gain 1.2)
    $ asdf

d2
